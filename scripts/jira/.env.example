# Jira Cloud credentials
# Email of your Atlassian account (the one you log into Jira with)
JIRA_USER_EMAIL=

# API token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
# Note: this is NOT your Atlassian password
JIRA_CLOUD_API=

# Your Jira Cloud instance URL (without trailing slash)
# e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=
